{
  "name": "framework",
  "version": "1.0.0",
  "description": "The system behind the trade.",
  "author": "Framework",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "generate-assets": "node build/generate-assets.js",
    "build:win": "electron-builder --win",
    "build:mac": "node build/generate-assets.js && electron-builder --mac",
    "build:all": "node build/generate-assets.js && electron-builder --win --mac"
  },
  "build": {
    "appId": "com.framework.app",
    "productName": "Framework",
    "copyright": "Copyright © 2025 Framework. All rights reserved.",
    "icon": "build/icon.png",
    "files": [
      "main.js",
      "preload.js",
      "build/**",
      "package.json"
    ],
    "extraMetadata": {
      "main": "main.js"
    },
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "darkModeSupport": true
    },
    "dmg": {
      "title": "Framework",
      "background": "build/dmg-background.png",
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        { "x": 150, "y": 185, "type": "file" },
        { "x": 390, "y": 185, "type": "link", "path": "/Applications" }
      ],
      "iconSize": 100
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Framework",
      "displayLanguageSelector": false,
      "license": null
    },
    "publish": {
      "provider": "github",
      "owner": "felixj0nes",
      "repo": "framework-desktop",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  }
}
